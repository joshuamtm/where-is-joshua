<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Saturday May 16 — Manhattan Wander</name>
    <description>Grand Central → Central Park → Hell's Kitchen → Greenwich Village → East Village. 12 stops, north-to-south, walking pace. Anchored by the 9th Ave Food Festival (midday) and DanceFest at Tompkins Square Park (evening).</description>

    <Style id="stopStyle">
      <IconStyle>
        <color>ff2196f3</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="routeStyle">
      <LineStyle>
        <color>ffe91e63</color>
        <width>4</width>
      </LineStyle>
    </Style>

    <Placemark>
      <name>1 — Grand Central Terminal (9:00 AM)</name>
      <description><![CDATA[
        <b>Start under the celestial ceiling.</b><br/>
        Quick coffee in the food court, then head north on Madison toward the park.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9772,40.7527,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>2 — Bethesda Terrace &amp; Fountain (9:45 AM)</name>
      <description><![CDATA[
        <b>Enter at Grand Army Plaza, walk down the Mall, through the Bethesda arcade.</b><br/>
        Spring is doing its thing.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9712,40.7740,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>3 — Belvedere Castle (10:30 AM)</name>
      <description><![CDATA[
        <b>Through the Ramble to the castle.</b><br/>
        The best view in the park from the upper deck.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9692,40.7794,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>4 — Columbus Circle (11:30 AM)</name>
      <description><![CDATA[
        <b>Exit the park southwest.</b><br/>
        Slow lap around the fountain before heading south on 9th Ave.<br/>
        <i>~15 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9819,40.7681,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>5 — 9th Ave Food Festival (12:00 PM)</name>
      <description><![CDATA[
        <b>Enter at 57th, graze south to 42nd.</b><br/>
        51st year. Mile-long. Don't fill up on the first three blocks.<br/>
        <i>~120 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9857,40.7679,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>6 — High Line, 30th St entrance (2:15 PM)</name>
      <description><![CDATA[
        <b>Walk south on the elevated park.</b><br/>
        Full bloom in mid-May.<br/>
        <i>~45 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0023,40.7528,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>7 — Little Island (3:00 PM)</name>
      <description><![CDATA[
        <b>Hudson views, 15–20 minutes. Pier 55.</b><br/>
        <i>~25 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0103,40.7420,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>8 — Caffè Reggio (3:45 PM)</name>
      <description><![CDATA[
        <b>1927. America's first cappuccino machine is still on the bar.</b><br/>
        Sit, regroup.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0004,40.7303,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>9 — Washington Square Park (4:30 PM)</name>
      <description><![CDATA[
        <b>Find a chess hustler. Sit at the fountain.</b><br/>
        The afternoon pause before DanceFest.<br/>
        <i>~45 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9973,40.7309,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>10 — Astor Place &amp; St Marks (5:30 PM)</name>
      <description><![CDATA[
        <b>Cube spin. Down St Marks toward Tompkins.</b><br/>
        <i>~25 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9899,40.7295,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>11 — Tompkins Square Park, DanceFest (6:00 PM)</name>
      <description><![CDATA[
        <b>Catch the last hour of DanceFest.</b><br/>
        Multiple stages until 7 PM. The day's evening anchor.<br/>
        <i>~75 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9818,40.7264,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>12 — Veselka (7:30 PM)</name>
      <description><![CDATA[
        <b>Pierogies, borscht, latkes.</b><br/>
        Three blocks from Tompkins. Open 24h on Saturday.<br/>
        <i>~75 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9871,40.7290,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>Route — walking path</name>
      <description>Approximate walking line through the 12 stops, north-to-south.</description>
      <styleUrl>#routeStyle</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          -73.9772,40.7527,0
          -73.9712,40.7740,0
          -73.9692,40.7794,0
          -73.9819,40.7681,0
          -73.9857,40.7679,0
          -74.0023,40.7528,0
          -74.0103,40.7420,0
          -74.0004,40.7303,0
          -73.9973,40.7309,0
          -73.9899,40.7295,0
          -73.9818,40.7264,0
          -73.9871,40.7290,0
        </coordinates>
      </LineString>
    </Placemark>

  </Document>
</kml>
