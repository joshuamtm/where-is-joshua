<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Saturday May 16 — Manhattan Wander</name>
    <description>Grand Central → Central Park → Hell's Kitchen → Hudson River Park → Greenwich Village → East Village. 11 stops, north-to-south then a Hudson detour, walking pace. Anchored by the 9th Ave Food Festival (midday) and a Pier 57 lunch break (afternoon).</description>

    <Style id="stopStyle">
      <IconStyle>
        <color>ff2196f3</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="routeStyle">
      <LineStyle>
        <color>ffe91e63</color>
        <width>4</width>
      </LineStyle>
    </Style>

    <Placemark>
      <name>1 — Grand Central Terminal (10:00 AM)</name>
      <description><![CDATA[
        <b>Start under the celestial ceiling.</b><br/>
        Quick coffee in the food court, then head north on Madison toward the park.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9772,40.7527,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>2 — Bethesda Terrace &amp; Fountain (10:45 AM)</name>
      <description><![CDATA[
        <b>Enter at Grand Army Plaza, walk down the Mall, through the Bethesda arcade.</b><br/>
        Spring is doing its thing.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9712,40.7740,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>3 — Belvedere Castle (11:30 AM)</name>
      <description><![CDATA[
        <b>Through the Ramble to the castle.</b><br/>
        The best view in the park from the upper deck.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9692,40.7794,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>4 — Columbus Circle (12:30 PM)</name>
      <description><![CDATA[
        <b>Exit the park southwest.</b><br/>
        Slow lap around the fountain before heading south on 9th Ave.<br/>
        <i>~15 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9819,40.7681,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>5 — 9th Ave Food Festival (1:00 PM)</name>
      <description><![CDATA[
        <b>Enter at 57th, graze south to 42nd.</b><br/>
        51st year. Mile-long. Don't fill up on the first three blocks.<br/>
        <i>~120 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9857,40.7679,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>6 — Pier 57, Hudson River Park (3:30 PM)</name>
      <description><![CDATA[
        <b>Lunch + rest at the river.</b><br/>
        Market 57 food hall on the ground, rooftop park up top. The pivot point before turning east into the Village.<br/>
        <i>~90 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0103,40.7434,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>7 — Caffè Reggio (5:15 PM)</name>
      <description><![CDATA[
        <b>1927. America's first cappuccino machine is still on the bar.</b><br/>
        Sit, regroup.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0004,40.7303,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>8 — Washington Square Park (6:00 PM)</name>
      <description><![CDATA[
        <b>Find a chess hustler. Sit at the fountain.</b><br/>
        The afternoon pause before DanceFest.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9973,40.7309,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>9 — Astor Place &amp; St Marks (6:45 PM)</name>
      <description><![CDATA[
        <b>Cube spin. Down St Marks toward Tompkins.</b><br/>
        <i>~20 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9899,40.7295,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>10 — Tompkins Square Park, DanceFest (7:15 PM)</name>
      <description><![CDATA[
        <b>Catch the tail end if anything's still running</b><br/>
        Or just absorb the post-fest park energy.<br/>
        <i>~45 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9818,40.7264,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>11 — Veselka (8:15 PM)</name>
      <description><![CDATA[
        <b>Pierogies, borscht, latkes.</b><br/>
        Three blocks from Tompkins. Open 24h on Saturday.<br/>
        <i>~75 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9871,40.7290,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>Route — walking path</name>
      <description>Approximate walking line through the 11 stops, north-to-south with a Hudson River detour.</description>
      <styleUrl>#routeStyle</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          -73.9772,40.7527,0
          -73.9712,40.7740,0
          -73.9692,40.7794,0
          -73.9819,40.7681,0
          -73.9857,40.7679,0
          -74.0103,40.7434,0
          -74.0004,40.7303,0
          -73.9973,40.7309,0
          -73.9899,40.7295,0
          -73.9818,40.7264,0
          -73.9871,40.7290,0
        </coordinates>
      </LineString>
    </Placemark>

  </Document>
</kml>
