<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Saturday May 16 — Manhattan Wander</name>
    <description>Grand Central → Central Park → Hell's Kitchen → Hudson River Park → Washington Square (chess) → LES (tattoo) → Tompkins. 9 stops, walking pace, with a 6 PM Daredevil tattoo as the late-day anchor.</description>

    <Style id="stopStyle">
      <IconStyle>
        <color>ff2196f3</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="routeStyle">
      <LineStyle>
        <color>ffe91e63</color>
        <width>4</width>
      </LineStyle>
    </Style>

    <Placemark>
      <name>1 — Grand Central Terminal (10:00 AM)</name>
      <description><![CDATA[
        <b>Start under the celestial ceiling.</b><br/>
        Quick coffee in the food court, then head north on Madison toward the park.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9772,40.7527,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>2 — Bethesda Terrace &amp; Fountain (10:45 AM)</name>
      <description><![CDATA[
        <b>Enter at Grand Army Plaza, walk down the Mall, through the Bethesda arcade.</b><br/>
        Spring is doing its thing.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9712,40.7740,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>3 — Belvedere Castle (11:30 AM)</name>
      <description><![CDATA[
        <b>Through the Ramble to the castle.</b><br/>
        The best view in the park from the upper deck.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9692,40.7794,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>4 — Columbus Circle (12:30 PM)</name>
      <description><![CDATA[
        <b>Exit the park southwest.</b><br/>
        Slow lap around the fountain before heading south on 9th Ave.<br/>
        <i>~15 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9819,40.7681,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>5 — 9th Ave Food Festival (1:00 PM)</name>
      <description><![CDATA[
        <b>Enter at 57th, graze south to 42nd.</b><br/>
        51st year. Mile-long. Don't fill up on the first three blocks.<br/>
        <i>~120 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9857,40.7679,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>6 — Pier 57, Hudson River Park (3:30 PM)</name>
      <description><![CDATA[
        <b>Lunch + rest at the river.</b><br/>
        Market 57 food hall on the ground, rooftop park up top. The pivot before heading east to chess.<br/>
        <i>~60 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0103,40.7434,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>7 — Washington Square Park, chess (4:45 PM)</name>
      <description><![CDATA[
        <b>The real reason for this detour.</b><br/>
        Sit at the chess tables in the southwest corner, find a hustler, play. Leave by 5:45 to cab to Daredevil.<br/>
        <i>~60 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9973,40.7309,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>8 — Daredevil Tattoo (6:00 PM)</name>
      <description><![CDATA[
        <b>Booked appointment.</b><br/>
        141 Division St, edge of LES and Chinatown. Cab from Washington Sq. Shop houses the NYC Tattoo History Museum.<br/>
        <i>~90 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9919,40.7138,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>9 — Tompkins Square Park (7:45 PM)</name>
      <description><![CDATA[
        <b>12-min walk north from Daredevil.</b><br/>
        Catch the post-DanceFest park energy. Last stop — home from here.<br/>
        <i>~45 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9818,40.7264,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>Route — walking path</name>
      <description>Approximate path. Cab segment from Washington Sq (7) to Daredevil (8).</description>
      <styleUrl>#routeStyle</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          -73.9772,40.7527,0
          -73.9712,40.7740,0
          -73.9692,40.7794,0
          -73.9819,40.7681,0
          -73.9857,40.7679,0
          -74.0103,40.7434,0
          -73.9973,40.7309,0
          -73.9919,40.7138,0
          -73.9818,40.7264,0
        </coordinates>
      </LineString>
    </Placemark>

  </Document>
</kml>
