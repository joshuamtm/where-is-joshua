<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Saturday May 16 — Manhattan Wander</name>
    <description>Grand Central → Central Park → Hell's Kitchen → Hudson River Park → LES → Greenwich Village → East Village. 11 stops, walking pace, with a Daredevil tattoo appointment anchoring the late afternoon.</description>

    <Style id="stopStyle">
      <IconStyle>
        <color>ff2196f3</color>
        <scale>1.2</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="routeStyle">
      <LineStyle>
        <color>ffe91e63</color>
        <width>4</width>
      </LineStyle>
    </Style>

    <Placemark>
      <name>1 — Grand Central Terminal (10:00 AM)</name>
      <description><![CDATA[
        <b>Start under the celestial ceiling.</b><br/>
        Quick coffee in the food court, then head north on Madison toward the park.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9772,40.7527,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>2 — Bethesda Terrace &amp; Fountain (10:45 AM)</name>
      <description><![CDATA[
        <b>Enter at Grand Army Plaza, walk down the Mall, through the Bethesda arcade.</b><br/>
        Spring is doing its thing.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9712,40.7740,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>3 — Belvedere Castle (11:30 AM)</name>
      <description><![CDATA[
        <b>Through the Ramble to the castle.</b><br/>
        The best view in the park from the upper deck.<br/>
        <i>~30 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9692,40.7794,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>4 — Columbus Circle (12:30 PM)</name>
      <description><![CDATA[
        <b>Exit the park southwest.</b><br/>
        Slow lap around the fountain before heading south on 9th Ave.<br/>
        <i>~15 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9819,40.7681,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>5 — 9th Ave Food Festival (1:00 PM)</name>
      <description><![CDATA[
        <b>Quick graze, one hour only.</b><br/>
        Enter at 57th, move with intent, hit the highlights. 4 PM appointment waiting.<br/>
        <i>~60 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9857,40.7679,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>6 — Pier 57, Hudson River Park (2:30 PM)</name>
      <description><![CDATA[
        <b>Lunch + brief rest at the river.</b><br/>
        Market 57 food hall on the ground, rooftop park up top. Cab east from here to Daredevil.<br/>
        <i>~60 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0103,40.7434,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>7 — Daredevil Tattoo (4:00 PM)</name>
      <description><![CDATA[
        <b>Booked appointment.</b><br/>
        141 Division St, edge of LES and Chinatown. Shop houses the NYC Tattoo History Museum — original flash from Samuel O'Reilly, Bert Grimm, Cap Coleman.<br/>
        <i>~90 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9919,40.7138,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>8 — Caffè Reggio (5:45 PM)</name>
      <description><![CDATA[
        <b>1927. America's first cappuccino machine is still on the bar.</b><br/>
        Sit, regroup, ice the new ink.<br/>
        <i>~25 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-74.0004,40.7303,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>9 — Washington Square Park (6:15 PM)</name>
      <description><![CDATA[
        <b>Find a chess hustler. Sit at the fountain.</b><br/>
        <i>~25 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9973,40.7309,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>10 — Astor Place &amp; St Marks (6:50 PM)</name>
      <description><![CDATA[
        <b>Cube spin. Down St Marks toward Tompkins.</b><br/>
        <i>~20 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9899,40.7295,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>11 — Tompkins Square Park, DanceFest (7:15 PM)</name>
      <description><![CDATA[
        <b>Catch the tail end if anything's still running, or just absorb the post-fest park energy.</b><br/>
        Last stop — home from here (or from Caffè Reggio earlier, if the day's done).<br/>
        <i>~45 min</i>
      ]]></description>
      <styleUrl>#stopStyle</styleUrl>
      <Point>
        <coordinates>-73.9818,40.7264,0</coordinates>
      </Point>
    </Placemark>

    <Placemark>
      <name>Route — walking path</name>
      <description>Approximate walking line through the 11 stops. Cab east from Pier 57 (stop 6) to Daredevil (stop 7).</description>
      <styleUrl>#routeStyle</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
          -73.9772,40.7527,0
          -73.9712,40.7740,0
          -73.9692,40.7794,0
          -73.9819,40.7681,0
          -73.9857,40.7679,0
          -74.0103,40.7434,0
          -73.9919,40.7138,0
          -74.0004,40.7303,0
          -73.9973,40.7309,0
          -73.9899,40.7295,0
          -73.9818,40.7264,0
        </coordinates>
      </LineString>
    </Placemark>

  </Document>
</kml>
